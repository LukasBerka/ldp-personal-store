@prefix dct: <http://purl.org/dc/terms/> .
@prefix cal: <http://example.org/cal#> .

<http://localhost:8000/calendar/work/sprint-review>
    a cal:Event ;
    dct:title "Sprint review" ;
    cal:date "2026-07-10" ;
    cal:start "2026-07-10T14:00:00Z" ;
    cal:location "Meeting room B" ;
    cal:calendar <http://localhost:8000/calendar/work/> ;
    cal:privateNote "Demo the view engine only if the blob rewrite bug is fixed." ;
    cal:attendee "alice@example.org", "carol@example.org", "dave@example.org" .
