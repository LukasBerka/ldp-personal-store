LDP_ADMIN_TOKEN=secret
LDP_BASE_URI=http://localhost:8000/

LDP_STORAGE_ROOT=./data

LDP_HOST=127.0.0.1
LDP_PORT=8000

LDP_RELOAD=false

LDP_TLS_MODE=off

# TLS key and certificate, required when LDP_TLS_MODE=required.
# LDP_SSL_KEYFILE=./certs/key.pem
# LDP_SSL_CERTFILE=./certs/cert.pem


# Engine token (PLAINTEXT) the view engine presents on the engine->storage
# boundary. Only its SHA-256 hash is persisted. Leave unset for the bundled
# deployment (a fresh token is issued in-memory each startup); set it when the
# engine runs as a separate process against a remote storage server.
# LDP_ENGINE_TOKEN=

# Base URL of the upstream storage server the engine talks to. Leave unset for
# the bundled deployment (in-process ASGI transport, no network socket); set it
# to run the engine against a storage server listening elsewhere.
# LDP_STORAGE_URL=http://127.0.0.1:8001/

LDP_CORS_ALLOW_ORIGINS=*
