LDP_ADMIN_TOKEN=secret
LDP_BASE_URI=http://localhost:8000/

LDP_STORAGE_ROOT=./data

LDP_HOST=127.0.0.1
LDP_PORT=8000

LDP_RELOAD=false

LDP_TLS_MODE=off

# TLS key and certificate, required when LDP_TLS_MODE=required.
# LDP_SSL_KEYFILE=./certs/key.pem
# LDP_SSL_CERTFILE=./certs/cert.pem


# --- Split deployment ---------------------------------------------------------
# The settings below only take effect when the view engine and storage run as
# separate processes. The bundled single-process pod leaves them all unset.

# LDP_ENGINE_TOKEN=

# Base URL of the upstream storage server the engine talks to. Leave unset for
# the bundled deployment (in-process ASGI transport, no network socket); set it
# to run the engine against a storage server listening elsewhere.
# LDP_STATE_STORAGE_URL=http://127.0.0.1:8001/

# Named graph holding the engine's operating state (token/view/policy records and
# the access log), kept out of view-CONSTRUCT scope. A stable logical name the
# engine and store agree on; this server realizes it as its .system/ subtree.
# LDP_STATE_GRAPH=urn:ldp:engine-state

# The store the engine queries for view CONSTRUCTs and binary reads, as opposed
# to the state store (LDP_STATE_STORAGE_URL) that holds the engine's own records. Leave
# unset to co-locate both on one server; set it to point the engine at a separate
# SPARQL/LDP data source
# LDP_DATA_SOURCE_URL=http://127.0.0.1:8002/

# The namespace the data-source resources carry: what the engine rewrites into
# gated proxy URLs and guards the blob endpoint against. Leave unset to match the
# engine's own public base (LDP_BASE_URI).
# LDP_DATA_SOURCE_BASE_URI=http://localhost:8000/

# Credential the engine presents to the data source. Leave unset to reuse the
# engine token
# LDP_DATA_SOURCE_TOKEN=

# Auth scheme the engine uses against the data source: bearer | basic
# LDP_DATA_SOURCE_AUTH=bearer

LDP_CORS_ALLOW_ORIGINS=*
