@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ns1: <https://lukasberka.github.io/ldp-personal-store/vocab#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://localhost:8000/.system/views/album> a ns1:View ;
    dcterms:description "Photos of one album: image links, titles and capture dates. Image links stream the photo in its native format."^^xsd:string ;
    dcterms:title "Photo album"^^xsd:string ;
    ns1:constructTemplate """PREFIX dct: <http://purl.org/dc/terms/>
PREFIX pho: <http://example.org/photo#>
CONSTRUCT { ?photo dct:title ?t ; pho:takenOn ?d }
WHERE     { ?photo dct:title ?t ; pho:takenOn ?d ;
                   pho:album ?album }"""^^xsd:string ;
    ns1:contentTypeHint "text/turtle"^^xsd:string ;
    ns1:parameter [ ns1:paramName "album"^^xsd:string ;
            ns1:paramType "iri"^^xsd:string ] ;
    ns1:viewRetrievalCount 2 .

