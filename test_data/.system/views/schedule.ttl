@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ns1: <urn:pod:vocab:> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://localhost:8000/.system/views/schedule> a ns1:View ;
    dcterms:description "Upcoming events, titles and dates only."^^xsd:string ;
    dcterms:title "Two-week schedule"^^xsd:string ;
    ns1:constructTemplate """PREFIX dct: <http://purl.org/dc/terms/>
PREFIX cal: <http://example.org/cal#>
CONSTRUCT { ?e dct:title ?t ; cal:date ?d }
WHERE     { ?e dct:title ?t ; cal:date ?d ;
               cal:calendar ?calendar }"""^^xsd:string ;
    ns1:contentTypeHint "text/turtle"^^xsd:string ;
    ns1:parameter [ ns1:paramName "calendar"^^xsd:string ;
            ns1:paramType "iri"^^xsd:string ] ;
    ns1:viewRetrievalCount 2 .

