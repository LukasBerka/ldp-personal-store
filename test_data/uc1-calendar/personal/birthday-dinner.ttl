@prefix dct: <http://purl.org/dc/terms/> .
@prefix cal: <http://example.org/cal#> .

<http://localhost:8000/calendar/personal/birthday-dinner>
    a cal:Event ;
    dct:title "Mum's birthday dinner" ;
    cal:date "2026-07-11" ;
    cal:start "2026-07-11T18:00:00Z" ;
    cal:location "U Fleku, Prague" ;
    cal:calendar <http://localhost:8000/calendar/personal/> ;
    cal:privateNote "Present is hidden in the wardrobe; sister still owes half." ;
    cal:attendee "mum", "dad", "sister" .
