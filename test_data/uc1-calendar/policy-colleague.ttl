# UC1 colleague grant (mirrors the ch7 example): expires Aug 1, at most 100
# retrievals, and at least 5 seconds between consecutive retrievals.
<> a <https://lukasberka.github.io/ldp-personal-store/vocab#Policy> ;
  <https://lukasberka.github.io/ldp-personal-store/vocab#expiresAt>     "2026-08-01T00:00:00Z" ;
  <https://lukasberka.github.io/ldp-personal-store/vocab#maxRetrievals> 100 ;
  <https://lukasberka.github.io/ldp-personal-store/vocab#minInterval>   5 .
