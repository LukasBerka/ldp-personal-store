@prefix dct: <http://purl.org/dc/terms/> .
@prefix cal: <http://example.org/cal#> .

<http://localhost:8000/calendar/work/client-call>
    a cal:Event ;
    dct:title "Client call: Q3 roadmap" ;
    cal:date "2026-07-16" ;
    cal:start "2026-07-16T10:30:00Z" ;
    cal:location "Zoom" ;
    cal:calendar <http://localhost:8000/calendar/work/> ;
    cal:privateNote "Client is unhappy about the delayed milestone; prepare fallback offer." ;
    cal:attendee "eve@client.example.com" .
