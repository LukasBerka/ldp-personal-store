@prefix dct: <http://purl.org/dc/terms/> .
@prefix cal: <http://example.org/cal#> .

# Outside the two-week window (2026-07-05 .. 2026-07-19): the windowed schedule
# view must NOT return this event.
<http://localhost:8000/calendar/work/quarterly-planning>
    a cal:Event ;
    dct:title "Quarterly planning offsite" ;
    cal:date "2026-08-03" ;
    cal:start "2026-08-03T09:00:00Z" ;
    cal:location "Hotel Aurora, Brno" ;
    cal:calendar <http://localhost:8000/calendar/work/> ;
    cal:privateNote "Book train tickets by mid-July." ;
    cal:attendee "alice@example.org", "bob@example.org", "carol@example.org" .
