@prefix pod:     <https://lukasberka.github.io/ldp-personal-store/vocab#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

# UC2: read access to one album for a family member. The photo URIs in the
# result are pod resources, so the engine rewrites them to gated
# /.engine/blob/ URLs the consumer can stream with the same token; the GPS
# metadata is never selected.
<> a pod:View ;
   dcterms:title "Photo album" ;
   dcterms:description "Photos of one album: image links, titles and capture dates. Image links stream the photo in its native format." ;
   pod:constructTemplate """
     PREFIX dct: <http://purl.org/dc/terms/>
     PREFIX pho: <http://example.org/photo#>
     CONSTRUCT { ?photo dct:title ?t ; pho:takenOn ?d }
     WHERE     { ?photo dct:title ?t ; pho:takenOn ?d ;
                        pho:album ?album }
   """ ;
   pod:contentTypeHint "text/turtle" ;
   pod:parameter [ pod:paramName "album" ;
                   pod:paramType "iri" ] .
